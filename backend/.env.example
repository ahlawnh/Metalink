# Copy to `.env.local` for local development.
# Never commit real secrets.

# APP_ENV=development
# LOG_LEVEL=info
# MOCK_AI=true
# ENABLE_INGESTION_LOOP=true
# MOCK_TELEMETRY_SCENARIO=overdose_case
# MOCK_BROADCAST_INTERVAL_SECONDS=1.0
# HEARTBEAT_INTERVAL_SECONDS=5.0
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
# LIVEKIT_ROOM=d-spatch-demo
# LIVEKIT_IDENTITY=d-spatch-backend
# LIVEKIT_CALLER_IDENTITY=caller
# LIVEKIT_DISPATCHER_IDENTITY_PREFIX=metalink-operator
# FRAME_SAMPLE_INTERVAL_SECONDS=2.5
# TELEMETRY_COALESCE_MS=100
# AEGIS_LOG_MOCK_TICKS=true
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=multi
# DEEPGRAM_ENDPOINTING=100

# Example provider keys (only if your backend calls providers directly):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPGRAM_API_KEY=...
