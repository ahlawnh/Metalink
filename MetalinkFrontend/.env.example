# Backend (FastAPI + uvicorn default). Used to build ws://host/api/ws/telemetry
VITE_TELEMETRY_API_ORIGIN=http://127.0.0.1:8000

# Optional: full WebSocket URL override
# VITE_TELEMETRY_WS_URL=ws://127.0.0.1:8000/api/ws/telemetry

# Optional: mock scenario query (?scenario=) — matches backend MOCK_TELEMETRY_SCENARIO values
# VITE_TELEMETRY_SCENARIO=overdose_case

# Google Maps JavaScript API (Maps SDK for interactive caller map). Leave unset to show coords + external link only.
# VITE_GOOGLE_MAPS_API_KEY=

# Optional fallback MP4/HLS URL when telemetry.video.streamUrl is empty (development).
# VITE_VIDEO_STREAM_URL=

# LiveKit — when URL + token are set, Live Feed uses subscriber-only RTC (caller camera only).
# VITE_LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
# VITE_LIVEKIT_TOKEN=
# Optional participant identity filters (remote identities):
# VITE_LIVEKIT_CALLER_PARTICIPANT_IDENTITY=caller
# VITE_LIVEKIT_OPERATOR_PARTICIPANT_IDENTITY=dispatcher
