# Backend (FastAPI + uvicorn default). Used to build ws://host/api/ws/telemetry
VITE_TELEMETRY_API_ORIGIN=http://127.0.0.1:8000

# Optional: full WebSocket URL override
# VITE_TELEMETRY_WS_URL=ws://127.0.0.1:8000/api/ws/telemetry

# Optional: mock scenario query (?scenario=) — matches backend MOCK_TELEMETRY_SCENARIO values
# VITE_TELEMETRY_SCENARIO=overdose_case
