# Backend (FastAPI + uvicorn default). Used to build ws://host/api/ws/telemetry
# and to poll GET /api/incident/telemetry/recent when the telemetry WebSocket is offline
# (merges browser GPS + rPPG vitals posted by the incident_feed app into the dashboard).
VITE_TELEMETRY_API_ORIGIN=http://127.0.0.1:8000

# Optional: full WebSocket URL override
# VITE_TELEMETRY_WS_URL=ws://127.0.0.1:8000/api/ws/telemetry

# Optional: mock scenario query (?scenario=) — matches backend MOCK_TELEMETRY_SCENARIO values
# VITE_TELEMETRY_SCENARIO=overdose_case

# Google Maps JavaScript API (Maps SDK for interactive caller map). Leave unset to show coords + external link only.
# VITE_GOOGLE_MAPS_API_KEY=

# Optional fallback MP4/HLS URL when telemetry.video.streamUrl is empty (development).
# VITE_VIDEO_STREAM_URL=

# LiveKit — use either (1) static env pair or (2) Metalink API token (recommended).
# (1) VITE_LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
#     VITE_LIVEKIT_TOKEN=...   # short-lived dev JWT only; prefer (2) in production
# (2) Set VITE_TELEMETRY_API_ORIGIN above; frontend GETs /api/livekit/token (no VITE_LIVEKIT_TOKEN).
# Optional: VITE_LIVEKIT_ROOM=  (display; room comes from API when using (2))
# VITE_LIVEKIT_CALLER_PARTICIPANT_IDENTITY=caller
# VITE_LIVEKIT_OPERATOR_PARTICIPANT_IDENTITY=metalink-operator
# VITE_LIVEKIT_BACKEND_PARTICIPANT_IDENTITY=aegis-link-backend
# Dispatcher dashboard publishes microphone audio after browser permission.
# The backend classifies identities starting with VITE_LIVEKIT_OPERATOR_PARTICIPANT_IDENTITY as dispatcher speech.
