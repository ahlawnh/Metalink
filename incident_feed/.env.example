# Public LiveKit websocket URL (same value as backend LIVEKIT_URL)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Default room name — must match backend LIVEKIT_ROOM / LIVEKIT ingest config
NEXT_PUBLIC_LIVEKIT_ROOM=aegis-link-demo

# Server-only (never expose to the browser). Same keys as backend LiveKit project.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional override for token route if you omit NEXT_PUBLIC_LIVEKIT_ROOM
LIVEKIT_ROOM=aegis-link-demo
