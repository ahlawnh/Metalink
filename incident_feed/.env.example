# Recommended: FastAPI base URL for server-side token proxy (secrets stay on backend).
# Works with HTTPS tunnels — the browser only talks to Next.js (same origin).
# Example: http://127.0.0.1:8000
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Browser → FastAPI telemetry WebSocket (CPR haptic cues for incident_feed). Same host as backend.
# NEXT_PUBLIC_TELEMETRY_WS_URL=ws://127.0.0.1:8000/api/ws/telemetry
# Or set origin only (ws/wss derived):
NEXT_PUBLIC_TELEMETRY_API_ORIGIN=http://127.0.0.1:8000

# Alternative alias (either works):
# LIVEKIT_TOKEN_BACKEND_URL=http://127.0.0.1:8000

# If BACKEND_INTERNAL_URL is unset, Next.js mints tokens locally using:
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_ROOM=d-spatch-demo
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM=d-spatch-demo
